@page "/Account/ForgotPassword"
@layout EmptyLayout
@using Microsoft.AspNetCore.Identity
@using NigerianPrimarySchool.Infrastructure.Identity
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Forgot Password — NPS</PageTitle>

<div class="nps-auth-wrapper">
    <div class="nps-auth-card">
        <h2 class="nps-auth-title">Reset Password</h2>
        <p class="nps-auth-sub">Enter your school email to receive a reset link.</p>

        @if (emailSent)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" AllowClose="false">
                If that email exists in our system, a password reset link has been sent.
            </RadzenAlert>
            <div style="margin-top:1rem;text-align:center">
                <a href="/Account/Login" class="nps-link">← Back to Login</a>
            </div>
        }
        else
        {
            <EditForm Model="model" OnValidSubmit="SendReset" FormName="forgot">
                <DataAnnotationsValidator />
                <RadzenFormField Text="Email Address" class="nps-field">
                    <InputText @bind-Value="model.Email" class="rz-textbox"
                               placeholder="you@school.edu.ng" />
                    <ValidationMessage For="() => model.Email" />
                </RadzenFormField>
                <RadzenButton ButtonType="ButtonType.Submit" Text="Send Reset Link"
                              Icon="send" ButtonStyle="ButtonStyle.Primary" class="nps-btn-full"
                              IsBusy="@busy" BusyText="Sending…" />
            </EditForm>
            <div style="margin-top:1rem;text-align:center">
                <a href="/Account/Login" class="nps-link">← Back to Login</a>
            </div>
        }
    </div>
</div>

@code {
    private ForgotModel model = new();
    private bool emailSent, busy;

    private async Task SendReset()
    {
        busy = true;
        var user = await UserManager.FindByEmailAsync(model.Email);
        if (user is not null && user.IsActive)
        {
            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            // TODO: Send token via IEmailSender (wire up in a future sprint)
            // Intentionally not revealing whether user exists (prevents email enumeration)
        }
        emailSent = true;
        busy = false;
    }

    private class ForgotModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
